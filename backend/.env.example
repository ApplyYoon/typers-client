# ──────────────────────────────────────────
# Typers Backend — 환경변수 예시
# 실제 .env 파일로 복사 후 값 채워서 사용
# ──────────────────────────────────────────

# PostgreSQL (개발: docker-compose DB 컨테이너 / 프로덕션: RDS 엔드포인트)
DATABASE_URL=postgresql+asyncpg://typers:change-this-password@db:5432/typers

# Redis (개발: docker-compose redis / 프로덕션: Upstash URL)
# Upstash 형식: rediss://default:PASSWORD@HOST.upstash.io:6379
REDIS_URL=redis://redis:6379

# JWT 서명 키 — 최소 32자 이상의 랜덤 문자열
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-char-string

# JWT 알고리즘 (변경 불필요)
ALGORITHM=HS256

# 토큰 만료 시간 (분) — 기본 7일
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 허용할 CORS 출처 (쉼표 구분)
# 개발: http://localhost:5173
# 프로덕션: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5175

# HTTPS 환경 여부 — 프로덕션에서 true 로 설정 (secure 쿠키 활성화)
HTTPS=false

# Docker Compose용 PostgreSQL 초기화 변수 (DATABASE_URL과 일치시킬 것)
POSTGRES_DB=typers
POSTGRES_USER=typers
POSTGRES_PASSWORD=change-this-password
